# HTTP server port inside the container or local process, digits only
PORT=4010

# Bearer token required by clients calling /mcp
MCP_BEARER_TOKEN=replace-me

# Base URL for the Vikunja instance, using http:// or https://
VIKUNJA_URL=https://vikunja.example.internal

# Vikunja API token used by this bridge for outbound calls
VIKUNJA_API_TOKEN=replace-me

# Set to false only when your Vikunja instance uses a self-signed certificate
VERIFY_SSL=true
